  "_meta": {
    "description": "Canonical vanishing point (VP) specifications for LTG environment generators.",
    "purpose": "Enables LTG_TOOL_sobel_vp_detect.py and vanishing_point_lint.py to look up expected VP_X/VP_Y automatically without requiring --vp-x-expected/--vp-y-expected flags on every invocation.",
    "format": {
      "generator": "LTG_TOOL_ filename (without .py)",
      "output_filename": "Expected PNG output filename",
      "canvas_w": "Canvas width in pixels",
      "canvas_h": "Canvas height in pixels",
      "vp_x": "Vanishing point X in pixels (at canvas size above)",
      "vp_y": "Vanishing point Y in pixels (at canvas size above)",
      "tolerance_px": "Acceptable pixel deviation for PASS (VP002 check)",
      "world_type": "real_world | glitch_layer | mixed",
      "notes": "Source of VP value (formula or constant)"
    },
    "usage_example": "python LTG_TOOL_sobel_vp_detect.py LTG_ENV_foo.png --vp-config vp_spec_config.json",
    "maintained_by": "Kai Nakamura — update whenever a background spec changes",
    "version": "1.0.0",
    "created_cycle": "C44"
  },
