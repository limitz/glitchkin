#!/usr/bin/env python3
"""put an idea in the ideabox."""

import os
from datetime import datetime

inbox = os.path.join(os.path.dirname(__file__), "ideabox")
os.makedirs(inbox, exist_ok=True)

print("Submit your idea (end with a single '.' on its own line):")
lines = []
while True:
    line = input()
    if line == ".":
        break
    lines.append(line)

body = "\n".join(lines).strip()
if not body:
    print("Empty message — aborted.")
    exit(1)

now = datetime.now()
timestamp = now.strftime("%Y%m%d_%H%M")
subject_slug = '_'.join(lines[0].split()[:5]).lower() #input("Short description for filename (e.g. fix_sf02_warmglow): ").strip()
subject_slug = subject_slug or "idea"

filename = f"{timestamp}_{subject_slug}.md"
filepath = os.path.join(inbox, filename)

content = f"""**Date:** {now.strftime("%Y-%m-%d %H:%M")}
**From:** Human

{body}
"""

with open(filepath, "w") as f:
    f.write(content)

print(f"Idea submitted to ideabox/{filename}")
